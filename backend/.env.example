# Copy this file to `.env` and fill in real values for local development.
# Never commit the real `.env` file.

# --- Database -----------------------------------------------------------
# Full SQLAlchemy-compatible PostgreSQL connection string.
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/app_db

# --- JWT Authentication ---------------------------------------------------
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- App -------------------------------------------------------------------
APP_NAME=Backend API
ENVIRONMENT=development
DEBUG=true

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
